# Python venv (for slack-bot)
.venv/

# Logs from cron-driven scripts
logs/*
!logs/.gitkeep

# Local state — user copies from *.example, or scripts populate
state/budget.yml
state/slack-config.yml
state/slack-app.yml
state/notified-writings.txt

# Local secrets
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
*.swp
*.swo

# Claude Code runtime — 공유할 것 (settings.json, hooks/) 제외 ignore
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
state/.last-role

# Prototype build artifacts (the-map-walker etc.)
outputs/code/**/node_modules/
outputs/code/**/dist/
