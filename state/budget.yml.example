# 사용량 예산 — 사용자가 state/budget.yml 로 복사 후 채움.
# 1차 소스: ccusage (5h billing block 활성 사용량 — 사용자 인터랙티브 + cron 합산).
#         npx -y ccusage@latest blocks --active --offline --json 결과를 매 check 때 박는다.
# Fallback: 자체 누적 카운터 (per-tick 보수 추정). ccusage 실패 시만 사용.
# state/budget.yml 은 .gitignore 에 의해 커밋되지 않는다.

plan: max-20x

# Per-tick safety cap (Anthropic billing 기준 USD).
# tick.sh 가 claude -p --max-budget-usd 로 강제.
per_tick_usd: 0.30

# 누적 한도 (placeholder — 사용자가 자신의 plan 에 맞춰 조정).
limits:
  session_5h_usd: 5.00          # 세션 5h 롤링 윈도우
  weekly_all_usd: 30.00         # 매주 토요일 10:00 KST 리셋
  weekly_sonnet_usd: 10.00      # Sonnet 만 (별도 추적은 v2)

# 임계 (한도 대비 비율).
thresholds:
  warn: 0.70                    # Slack warn
  pause: 0.90                   # 시스템 자동 OFF (current.md.paused = true)

# 리셋 시각 — 시스템이 자동 계산하여 갱신.
# 세션은 첫 사용 시각 + 5h. 주간은 가장 최근 토요일 10:00 KST.
state:
  session_started_at: null
  session_usd_used: 0.00         # fallback (자체 추정 누적)
  weekly_started_at: null
  weekly_all_usd_used: 0.00      # fallback (자체 추정 누적)
  weekly_sonnet_usd_used: 0.00   # fallback (자체 추정 누적)
  paused_at: null
  pause_reason: null
  last_check_at: null
  last_warn_sent_at: null        # 같은 임계로 반복 알림 방지

  # ── ccusage live (1차 소스) — usage-budget.sh check 가 매번 갱신. ──
  # fresh = live_updated_at 이 15 분 이내. fresh 면 임계 평가 시 self-counter 대신 사용.
  live_block_id: null
  live_block_start: null
  live_block_end: null
  live_block_cost_usd: null              # 활성 5h block 의 현재까지 누적 비용
  live_burn_rate_usd_per_hour: null      # 현재 burn rate
  live_projected_block_cost_usd: null    # block 끝까지 갈 때 예상 비용
  live_weekly_all_usd: null              # weekly_started_at 부터 ccusage daily 합계
  live_updated_at: null
  live_source: null                       # 'ccusage' | null (실패 시)

# tick 카운터 (보조 지표 — USD 가 정확하지 않을 때 fallback).
tick_count:
  session: 0
  weekly: 0
